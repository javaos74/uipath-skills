{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/ensure-uip.sh\"",
            "once": true,
            "statusMessage": "Checking uip, servo and rpa-tool installation..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-end-zip-project.sh\"",
            "statusMessage": "Archiving Studio project to Documents..."
          }
        ]
      }
    ]
  }
}
